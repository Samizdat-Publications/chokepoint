# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chokepoint

# AIS Data Sources (choose one for MVP)
# Option 1: aisstream.io (free) — https://aisstream.io/authenticate
AISSTREAM_API_KEY=

# Option 2: MarineTraffic (commercial) — https://www.marinetraffic.com/en/online-services/plans
MARINETRAFFIC_API_KEY=

# Option 3: Spire Maritime (commercial) — https://spire.com/maritime/
SPIRE_API_TOKEN=

# Which AIS source to use: aisstream | marinetraffic | spire
AIS_SOURCE=aisstream

# Oil Price APIs
EIA_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# Events
GDELT_ENABLED=true

# Pipeline settings
POLL_INTERVAL_SECONDS=900
LOG_LEVEL=INFO
